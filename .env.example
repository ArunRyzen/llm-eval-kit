# Copy to `.env`. All optional — the kit runs fully offline without keys.

# Enables the real AnthropicJudge (LLM-as-judge). Without it, use scorers / FakeJudge.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
MAX_TOKENS=512

# Default ship-gate threshold (fraction of cases that must pass)
THRESHOLD=0.8
