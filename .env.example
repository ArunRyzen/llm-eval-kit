# Copy to `.env`. All optional — the kit runs fully offline without keys.

# Live mode (recommended): enables the real GeminiJudge (LLM-as-judge).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Alternative judge: Claude. Used only when GEMINI_API_KEY is not set.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

MAX_TOKENS=512

# Default ship-gate threshold (fraction of cases that must pass)
THRESHOLD=0.8
